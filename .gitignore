# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
# testing
/coverage
# next.js
/.next/
/out/
# production
/build
# misc
.DS_Store
*.pem
# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
# env files (can opt-in for committing if needed)
.env*
# vercel
.vercel
# Claude Code local config (memory, plans, session notes — not for public repos)
.claude/
# typescript
*.tsbuildinfo
next-env.d.ts
.venv/
# raw fetcher dumps — regenerable via `npm run fetch:*`, consumed into mock-data.ts.
# Ignored to keep them out of search/diffs (delete a line to commit a snapshot).
/src/lib/boc-data.json
/src/lib/bonds-data.json
/src/lib/finnhub-data.json
/src/lib/fred-data.json
/src/lib/heatmap-data.json
/src/lib/market-data.json
/src/lib/twelvedata-data.json
/src/lib/yahoo-data.json
# auto-refresh logs and state
/logs/
/.last-refresh
